# Core runtime
AI_PROVIDER=deterministic
TTS_PROVIDER=mock
TTS_FALLBACK_PROVIDER=system
LLM_FALLBACK_ENABLED=true
FRONTEND_API_BASE_URL=http://127.0.0.1:8000/avatar-service

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (if AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_CA_BUNDLE=
GEMINI_API_KEY_FILE=.secrets/gemini_api_key

# Ollama (if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Limits + OCR
MAX_MESSAGE_CHARS=4000
MAX_TTS_CHARS=12000
MAX_TRAINING_FILE_BYTES=8000000
MAX_TRAINING_DOCS_PER_AVATAR=40
MAX_STUDENT_IMAGE_FILE_BYTES=6000000
OCR_ENABLED=true
OCR_MAX_PAGES=15
OCR_LANGUAGE=eng
HINGLISH_ENABLED=true

# CORS for split frontend/backend deployments
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_HEADERS=Content-Type, Authorization, X-User-Id
CORS_ALLOW_METHODS=GET, POST, DELETE, OPTIONS
